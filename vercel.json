{
  "version": 2,
  "rewrites": [
    { "source": "/api/sepbook-:action",            "destination": "/api/sepbook?action=:action" },
    { "source": "/api/campaign-:action",          "destination": "/api/campaign?action=:action" },
    { "source": "/api/finance-:action",           "destination": "/api/finance?action=:action" },
    { "source": "/api/coord-ranking",             "destination": "/api/misc?action=coord-ranking" },
    { "source": "/api/quiz-practice-check",       "destination": "/api/misc?action=quiz-practice-check" },
    { "source": "/api/challenge-action-submit",   "destination": "/api/misc?action=challenge-action-submit" },
    { "source": "/api/guardiao-vida-dashboard",   "destination": "/api/misc?action=guardiao-vida-dashboard" },
    { "source": "/api/profile-lookup",            "destination": "/api/misc?action=profile-lookup" },
    { "source": "/api/registration-options",      "destination": "/api/misc?action=registration-options" },
    { "source": "/api/reverse-geocode",           "destination": "/api/misc?action=reverse-geocode" },
    { "source": "/api/forum-mentions-mark-seen",  "destination": "/api/misc?action=forum-mentions-mark-seen" },
    {
      "source": "/((?!api/|@vite/|@react-refresh|@id/|@fs/|.*\\..*).*)",
      "destination": "/"
    }
  ],
  "headers": [
    {
      "source": "/((?!api/).*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(self), payment=()"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; font-src 'self' data:; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://nominatim.openstreetmap.org; media-src 'self' blob: https://*.supabase.co; worker-src 'self' blob:; frame-ancestors 'none';"
        },
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin"
        }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0"
        }
      ]
    }
  ]
}
